eData":null,"productListData":null,"categoryFilterList":[],"listdata":null,"productDetail":{"_id":"62949b207dfc152b58065beb","enable":true,"name":"OCH027-Executive Chair-Black","productTitle":"Peta High Back Chair - Black","description":null,"seoMarkup":"seo","keywords":"buy office chair online, buy office chair online near me, buy office chair online at low price","classification":null,"sku":"OCH027-Black","faq":[],"slug":"och027-executive-chair-black-2857","feature_image":"https://damroimages.blob.core.windows.net/damroimages/black27.jpg","gallery":[{"_id":"6878d3e6b4a37e5b7d6819ae","link":"https://damroimages.blob.core.windows.net/damroimages/black27-1.jpg","type":"image"},{"_id":"6878d3e6b4a37e3d8b6819af","link":"https://damroimages.blob.core.windows.net/damroimages/black27-2.jpg","type":"image"},{"_id":"6878d3e6b4a37e78856819b0","link":"https://damroimages.blob.core.windows.net/damroimages/black27-3.jpg","type":"image"},{"_id":"6878d3e6b4a37ecb366819b1","link":"https://damroimages.blob.core.windows.net/damroimages/black27-4.jpg","type":"image"}],"tag":"","stocks":{"offer":0,"_id":"62949b207dfc1510aa065bef","region":{"id":"60ae18731e3fc640d831ab15"},"quantity":1,"oldPrice":11690,"newPrice":11100,"shipin":"5","notificationQuantity":5},"oldPrice":11690,"newPrice":11100,"shipin":"5","quantity":1,"prdDetails":[{"key":"Dimensions","value":"W 66 cm x D 68 cm x H 136 cm"},{"key":"Primary Material","value":"Castors, Chair base, Gas lifter, Chair arm, Chair control, Press wood sheet, HR Foam, Polyester Fiber Sheet, Leatherette"},{"key":"Finish","value":"Leatherette"},{"key":"Style","value":"Modern"},{"key":"Warranty","value":"24 Months"},{"key":"Manufacturer","value":"D.R. Exports (Pvt) Ltd"}],"deliveryInstallation":null,"materialCare":"\u003cp\u003e\u003cstrong\u003eChairs\u003c/strong\u003e\u003c/p\u003e\r\n\u003cul\u003e\r\n\u003cli\u003eAvoid prolonged exposure to direct sunlight at all times. \u003c/li\u003e\r\n\u003cli\u003eAvoid using sharp and pointed objects on the surface. \u003c/li\u003e\r\n\u003cli\u003eKeep the furniture in well-ventilated place. \u003c/li\u003e\r\n\u003cli\u003eWipe surface with a soft and clean cloth. For cleaning surfaces with leatherette, plastic and metal use fabric with mildly soaked in mild detergent. Rinse thoroughly and dry with a soft cloth.\u003c/li\u003e\r\n\u003cli\u003eDo not use solvents or abrasive cleaners.\u003c/li\u003e\r\n\u003c/ul\u003e","overview":"Bring out your excellent taste in office furniture and enhance the way you work with this superbly comfortable and luxuriously executive high-back chair with adjustable height. The HR foam cushioned seat, tall backrest, and sturdy arms take away the strain from your body and provide optimum neck, back and arm support. So no more slouching, strains and backaches even if you work for long hours every day. A special mention goes to the curved contours of the chair and the patterned design at the backrest, which promise a superior seating experience. Order this ergonomic office chair now!","warranty":null,"packaging":"1 High Back Chair","termsConditions":null,"product_highlights":null,"productFeature":"Modern chair with high back and arms \r\nErgonomic design with full back support \r\nHR foam seat \r\nSturdy base with height-adjustable gas lifter and chair controls \r\nLeatherette upholstery \r\nCaster wheels at the base \r\nPolyester Fiber Sheet \r\nPress wood sheet \r\nPlush leatherette finish.","manufacturer":"D.R. Exports (Pvt) Ltd","packedby":"D.R. Exports (Pvt) Ltd","marketedby":"Damro Furniture (Pvt) Ltd","manufacturerAddress":null,"packedbyAddress":null,"marketedbyAddress":"No. A1 101, 4th Avenue, Next to Sri Mittai,  Anna Nagar, Chennai, Tamil Nadu, India - 600055","weight":"","numberofpacks":null,"countryoforigin":"Sri Lanka","parentId":"62949b207dfc152b58065beb","items_included":null,"warrantyTerms":"\u003cul\u003e\r\n\u003cli\u003e24 Months warranty against any manufacturing defects\u003c/li\u003e\r\n\u003cbr\u003e\r\n\u003cp\u003e\u003cstrong\u003eWHAT IS NOT COVERED UNDER WARRANTY\u003c/strong\u003e\u003c/p\u003e\r\n\u003cli\u003eCuts or scratches, or damage caused by normal wear.\u003c/li\u003e\r\n\u003cli\u003eDamage due to misuse and tampering. \u003c/li\u003e\r\n\u003cli\u003eDamages caused due to negligence. \u003c/li\u003e\r\n\u003c/ul\u003e","reviews":[],"dynamic":{"Color":[{"name":"Color","slug":"och027-executive-chair-brown-2858","image_link":"https://damroimages.blob.core.windows.net/damroimages/OCH 29 Brown.jpg","color_code":"#4e0b0b","enable":1},{"name":"Color","slug":"och027-executive-chair-black-2857","image_link":"https://damroimages.blob.core.windows.net/damroimages/Black.jpg","color_code":"#040202  ","enable":1}]},"region":[{"_id":"60ae18731e3fc640d831ab15","name":"Bengaluru","zones":[{"_id":"68623d013ad145feb7ccd824","name":"Bengaluru Zone 1","cities":[{"zipCode":[560001,560002,560003,560004,560005,560006,560007,560008,560009,560010,560011,560012,560013,560014,560015,560016,560017,560018,560019,560020,560021,560022,560023,560024,560025,560026,560027,560028,560029,560030,560032,560033,560034,560035,560036,560037,560038,560039,560040,560041,560042,560043,560045,560046,560047,560048,560049,560050,560051,560052,560053,560054,560055,560056,560058,560059,560060,560061,560062,560063,560064,560065,560066,560067,560068,560069,560070,560071,560072,560073,560074,560075,560076,560077,560078,560079,560080,560082,560083,560084,560085,560086,560087,560089,560090,560091,560092,560093,560094,560095,560096,560097,560098,560099,560100,560102,560103,560104,562106,562107,562125,562130,562149,562157,560081,560088,562123,562162],"_id":"63d79e2f5011dc3f5ae18304","name":"Bengaluru","description":"","displayOnHomePage":true,"sortOrder":1}],"shipping":[{"_id":"64b7c6c9946914e11789f27a","shippingPrice":500,"minTotal":1,"maxTotal":5000}],"shipppingInDays":5},{"_id":"68ccf5494efef84257dbbd5b","name":"KAR ALL CITIES ZONE1","cities":[{"zipCode":[571119,571107,571102,571130,571602,571617,571114,571312