: url(&quot;https://damroimages.blob.core.windows.net/damroimages/OCH%2029%20Brown.jpg&quot;); box-shadow: rgb(112, 112, 112) 0px 0px 4px; background-repeat: no-repeat; background-size: 37px 37px; background-position: center center;"></button></li><li class="DetailComponent_product_detail_color_list_item__1fjiu DetailComponent_active__1hSDY pdp_color_icon" style="padding: 1px; border: 2px solid rgb(249, 104, 104); width: 38px; height: 38px;"><button class="text_button position-absolute" style="background-image: url(&quot;https://damroimages.blob.core.windows.net/damroimages/Black.jpg&quot;); box-shadow: rgb(112, 112, 112) 0px 0px 4px; background-repeat: no-repeat; background-size: 37px 37px; background-position: center center;"></button></li></ul></div><div class="pdp_qty_section"><div><div class="d-flex align-items-center justify-content-between"><div class="d-flex align-items-center"><label class="DetailComponent_product_detail_label__1m5iK">Quantity</label><select name="quantity" id="count" class="DetailComponent_product_detail_quantity__1xlQr"><option value="1">1</option></select></div></div><span data-test="quantity_error"></span></div></div></div><form><div class="d-flex flex-wrap DetailComponent_product_detail_btns__2zPfh"><button class="DetailComponent_product_detail_btn__3fvms DetailComponent_product_detail_btn_cart__20K2U"><div class="DetailComponent_add_to_cart__10mFS"><svg xmlns="http://www.w3.org/2000/svg" width="33" height="32" viewBox="0 0 33 32" fill="none"><g clip-path="url(#clip0_3807_183)"><path d="M4.50488 6.76709H8.15335L10.5525 20.2919H24.8394L27.8033 8.7614H11.7024" stroke="#ffffff" stroke-width="1.4"></path><path d="M12.7236 25.2328C13.2656 25.2328 13.7049 24.7934 13.7049 24.2514C13.7049 23.7094 13.2656 23.27 12.7236 23.27C12.1816 23.27 11.7422 23.7094 11.7422 24.2514C11.7422 24.7934 12.1816 25.2328 12.7236 25.2328Z" stroke="#ffffff" stroke-width="1.4"></path><path d="M22.3373 25.2328C22.8793 25.2328 23.3187 24.7934 23.3187 24.2514C23.3187 23.7094 22.8793 23.27 22.3373 23.27C21.7953 23.27 21.356 23.7094 21.356 24.2514C21.356 24.7934 21.7953 25.2328 22.3373 25.2328Z" stroke="#ffffff" stroke-width="1.4"></path></g><defs><clippath id="clip0_3807_183"><rect width="24.287" height="20" fill="white" transform="translate(4.50488 6)"></rect></clippath></defs></svg>ADD TO CART</div></button><button class="DetailComponent_product_detail_btn__3fvms DetailComponent_product_detail_btn_buy__8q0jx"><svg width="18" height="26" viewBox="0 0 18 26" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15.6579 11.6438L9.30461 10.4571L12.1284 1.59157C12.1284 1.59157 12.1254 1.58752 12.1233 1.59061L2.60242 12.678L2.6019 12.6808L8.11342 13.7103L4.35386 23.5619C4.35386 23.5619 4.35762 23.5661 4.35898 23.5629L15.6618 11.6474L15.6579 11.6438Z" stroke="white" stroke-width="1.5" stroke-miterlimit="10" stroke-linecap="round"></path></svg>Buy now</button></div></form><div class="flex-wrap DetailComponent_product_detail_btns__2zPfh"><div class=""><span></span></div></div><div id="warranty"></div><div class="DetailComponent_product_detail_collapse__2UOXg accordion_desk accordion"><div class="DetailComponent_product_detail_collapse_card__xlS8e card"><div class="DetailComponent_product_detail_collapse_heading__Y9iMB DetailComponent_product_detail_collapse_heading_open__HJDr2 card-header"><button type="button" class="btn btn-link">Overview</button></div><div class="collapse show"><div class="DetailComponent_product_detail_collapse_body__14Wgk card-body"><div>Bring out your excellent taste in office furniture and enhance the way you work with this superbly comfortable and luxuriously executive high-back chair with adjustable height. The HR foam cushioned seat, tall backrest, and sturdy arms take away the strain from your body and provide optimum neck, back and arm support. So no more slouching, strains and backaches even if you work for long hours every day. A special mention goes to the curved contours of the chair and the patterned design at the backrest, which promise a superior seating experience. Order this ergonomic office chair now!</div></div></div></div><div class="DetailComponent_product_detail_collapse_card__xlS8e card"><div class="DetailComponent_product_detail_collapse_heading__Y9iMB false card-header"><button type="button" class="btn btn-link">Product Details</button></div><div class="collapse"><div class="DetailComponent_product_detail_collapse_body__14Wgk card-body"><ul class="DetailComponent_product_detail_collapse_list__37pwP"><li class="DetailComponent_product_detail_collapse_list_item__3oIy1"><span class="DetailComponent_spec_title_heading__6fX7d">Dimensions </span><span class="DetailComponent_spec_span_col__3B1Ef"> : </span><span><span class="DetailComponent_spec_value_span__3t_zK">W 66 cm x D 68 cm x H 136 cm</span></span></li><li class="DetailComponent_product_detail_collapse_list_item__3oIy1"><span class="DetailComponent_spec_title_heading__6fX7d">Primary Material </span><span class="DetailComponent_spec_span_col__3B1Ef"> : </span><span><span class="DetailComponent_spec_value_span__3t_zK">Castors, Chair base, Gas lifter, Chair arm, Chair control, Press wood sheet, HR Foam, Polyester Fiber Sheet, Leatherette</span></span></li><li class="DetailComponent_product_detail_collapse_list_item__3oIy1"><span class="DetailComponent_spec_title_heading__6fX7d">Finish </span><span class="DetailComponent_spec_span_col__3B1Ef"> : </span><span><span class="DetailComponent_spec_value_span__3t_zK">Leatherette</span></span></li><li class="DetailComponent_product_detail_collapse_list_item__3oIy1"><span class="DetailComponent_spec_title_heading__6fX7d">Style </span><span class="DetailComponent_spec_span_col__3B1Ef"> : </span><span><span class="DetailComponent_spec_value_span__3t_zK">Modern</span></span></li><li class="DetailComponent_product_detail_collapse_list_item__3oIy1"><span class="DetailComponent_spec_title_heading__6fX7d">Warranty </span><span class="DetailComponent_spec_span_col__3B1Ef"> : </span><span><span class="DetailComponent_spec_value_span__3t_zK">24 Months</span></span></li><li class="DetailComponent_product_detail_collapse_list_item__3oIy1"><span class="DetailComponent_spec_title_heading__6fX7d">Product Feature </span><span class="DetailComponent_spec_span_col__3B1Ef"> : </span><span><span class="DetailComponent_spec_value_span__3t_zK">Modern chair with high back and arms </span><li class="DetailComponent_spec_value__3sZlX">Ergonomic design with full back support </li><li class="DetailComponent_spec_value__3sZlX">HR foam seat </li><li class="DetailComponent_spec_value__3sZlX">Sturdy base with height-adjustable gas lifter and chair controls </li><li class="DetailComponent_spec_value__3sZlX">Leatherette upholstery </li><li class="DetailComponent_spec_value__3sZlX">Caster wheels at the base </li><li class="DetailComponent_spec_value__3sZlX">Polyester Fiber Sheet </li><li class="DetailComponent_spec_value__3sZlX">Press wood sheet </li><li class="DetailComponent_spec_value__3sZlX">Plush leatherette finish.</li></span></li><li class="DetailComponent_product_detail_collapse_list_item__3oIy1"></li></ul><button class="text_button DetailComponent_product_detail_collapse_readmore__3gjoy">Read More..</button></div></div></div><div class="DetailComponent_product_detail_collapse_card__xlS8e card"><div class="DetailComponent_product_detail_collapse_heading__Y9iMB false card-header"><button type="button" class="btn btn-link">Material care</button></div><div class="collapse"><div class="DetailComponent_product_detail_collapse_body__14Wgk card-body"><div><p><strong>Chairs</strong></p>
<ul>
<li>Avoid prolonged exposure to direct sunlight at all times. </li>
<li>Avoid using sharp and pointed objects on the surface. </li>
<li>Keep the furniture in well-ventilated place. </li>
<li>Wipe surface with a soft and clean cloth. For cleaning surfaces with leatherette, plastic and metal use fabric with mildly soaked in mild detergent. Rinse thoroughly and dry with a soft cloth.</li>
<li>Do not use solvents or abrasive cleaners.</li>
</ul></div></div></div></div><div class="DetailComponent_product_detail_collapse_card__xlS8e card"><div class="DetailComponent_product_detail_collapse_heading__Y9iMB false card-header"><button id="warrantyRef" type="button" class="btn btn-link">Warranty Terms</button></div><div class="collapse"><div class="DetailComponent_product_detail_collapse_body__14Wgk card-body"><div class="DetailComponent_warranty__24HqX"><ul>
<li>24 Months warranty against any manufacturing defects</li>
<br>
<p><strong>WHAT IS NOT COVERED UNDER WARRANTY</strong></p>
<li>Cuts or scratches, or damage caused by normal wear.</li>
<li>Damage due to misuse and tampering. </li>
<li>Damages caused due to negligence. </li>
</ul></div></div></div></div></div></div></div><div class="pdp_tab mb-3"><ul class="pdp_tab_sec"><li class="active">Overview</li><li class="">Product Details</li><li class="">Material Care</li><li class="">Warranty Terms</li></ul><div class="tab-content pdp_tab_content"><div><div class="right-line">Overview</div><div class="tab1_overview">Bring out your excellent taste in office furniture and enhance the way you work with this superbly comfortable and luxuriously executive high-back chair with adjustable height. The HR foam cushioned seat, tall backrest, and sturdy arms take away the strain from your body and provide optimum neck, back and arm support. So no more slouching, strains and backaches even if you work for long hours every day. A special mention goes to the curved contours of the chair and the patterned design at the backrest, which promise a superior seating experience. Order this ergonomic office chair now!</div></div></div></div></div></section><section class="showroom_container"><h4 class="title">Damro Showrooms Across India </h4><div class="offer_tag"><div class="body"><div class="name" style="min-width: 69px;">OFFER</div><div class="info"><span style="min-width: 32px; text-transform: capitalize;">GET</span><span class="red" style="min-width: fit-content;">UPTO 30% OFF</span><span class="main-subtitle-mobile"> &nbsp;&nbsp;&nbsp;&nbsp;on orders placed at your nearest stores </span></div></div></div><div class="cityCards"><div class="slick-slider slick-initialized" dir="ltr"><button type="button" data-role="none" class="slick-arrow slick-prev slick-disabled" style="display: block;"> Previous</button><div class="slick-list"><div class="slick-track" style="width: 1540px; opacity: 1; transform: translate3d(0px, 0px, 0px);"><div data-index="0" class="slick-slide slick-active slick-current" tabindex="-1" aria-hidden="false" style="outline: none; width: 154px;"><div><div class="city_section" title="Bangalore"><div class="city_name_sec"><div class="city-name-s