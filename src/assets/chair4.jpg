oter_nav_list_item\"\u003e\u003ca href=\"/refund-policy\"\u003eRefund \u0026 Policy\u003c/a\u003e\u003c/li\u003e\n\u003cli class=\"footer_nav_list_item\"\u003e\u003ca href=\"/cancel-policy\"\u003eCancellation Policy\u003c/a\u003e\u003c/li\u003e\n\u003cli class=\"footer_nav_list_item\"\u003e\u003ca href=\"/return-policy\"\u003eReturn Policy\u003c/a\u003e\u003c/li\u003e\n\u003c/ul\u003e\u003ch4 class=\"footer_nav_heading_social\"\u003eFollow Us\u003c/h4\u003e\u003cul class=\"d-flex align-items-center flex-wrap footer_nav_social\"\u003e\u003cli class=\"footer_nav_social_icons\"\u003e\u003ca href=\"https://twitter.com/damroindia1\" target=\"_blank\"\u003e\u003cimg src=\"https://damroimages.blob.core.windows.net/damroimages/twitter_icon.svg\" alt=\"\" /\u003e\u003c/a\u003e\u003c/li\u003e\u003cli class=\"footer_nav_social_icons\"\u003e\u003ca href=\"https://www.instagram.com/furnituredamro/?hl=en\" target=\"_blank\"\u003e\u003cimg src=\"https://damroimages.blob.core.windows.net/damroimages/insta_icon.svg\" alt=\"\" /\u003e\u003c/a\u003e\u003c/li\u003e\u003cli class=\"footer_nav_social_icons\"\u003e\u003ca href=\"https://www.youtube.com/channel/UC6SYkxEGnnhnFzpBId9vCcg\" target=\"_blank\"\u003e\u003cimg src=\"https://damroimages.blob.core.windows.net/damroimages/youtube_icon.svg\" alt=\"\" /\u003e\u003c/a\u003e\u003c/li\u003e \u003cli class=\"footer_nav_social_icons\"\u003e\u003ca href=\"https://www.facebook.com/damroindia\" target=\"_blank\"\u003e\u003cimg src=\"https://damroimages.blob.core.windows.net/damroimages/facebook_icon.svg\" alt=\"\" /\u003e\u003c/a\u003e\u003c/li\u003e \u003c/ul\u003e"},"quicklinksBlock":{"_id":"60abca2e77137f2610e733c8","blockId":"4","title":"Email and Phone","content":"\u003cul class=\"d-flex align-items-center flex-wrap footer_link\"\u003e\u003cli class=\"footer_link_item\"\u003e\u003ca href=\"/terms-conditions\"\u003eT\u0026amp;C\u003c/a\u003e\u003c/li\u003e\u003cli class=\"footer_link_item\"\u003e\u003ca href=\"/privacy-policy\"\u003ePrivacy Policy\u003c/a\u003e\u003c/li\u003e\u003cli class=\"footer_link_item\"\u003e\u003ca href=\"/disclaimer\"\u003eDisclaimer\u003c/a\u003e\u003c/li\u003e\u003c/ul\u003e"},"logoBlock":{"_id":"60abbbc777137f2610e733c6","blockId":"2","title":"Logo and description","content":"\u003cfigure class=\"footer_content_image\"\u003e\n\u003cimg\n    src=\"https://damroimages.blob.core.windows.net/damroimages/damro_logo.svg\"\n    alt=\"damro_logo\"\n  /\u003e\n\u003c/figure\u003e\n\u003cp class=\"footer_content_para\" style=\"text-align:justify;margin-bottom: 15px;\"\u003e\n  DAMRO is among the World's Largest Furniture Manufacturers offering a diverse range of modern and traditional furniture. \nSince Damro was established in 1986, it has achieved a rapid success and has expanded to over 250 showrooms in South Asia. \nDamro's success has grown from it's ability to produce high quality furniture at affordable prices with outstanding customer service.\n\u003c/p\u003e\n\u003cp class=\"footer_content_para\" style=\"text-align:justify;margin-bottom: 15px;\"\u003e\nPlease use the \u003cspan style=\"text-decoration: underline; cursor: pointer;\" onclick=\"openStoreLocator()\"\u003estore locator\u003c/span\u003e to find your nearest Damro showroom.\n\u003c/p\u003e\n\u003cp class=\"footer_content_para\" style=\"text-align:justify;margin-bottom: 15px;\"\u003e\nFor further enquiries contact or visit any Damro showroom where our friendly staff will gladly assist you.\n\u003c/p\u003e\n\u003cscript\u003e\n  function openStoreLocator() {\n    const otherPageUrl = \"https://stage.damroindia.com/showroom\";\n      window.location.href = otherPageUrl;\n  }\n\u003c/script\u003e"},"companyDetailBlock":{"_id":"60abbbfd77137f2610e733c7","blockId":"3","title":"Email and Phone","content":"\u003cdiv class=\"footer_content_link\"\u003e\u003clabel\u003e\u003cimg src=\"https://damroimages.blob.core.windows.net/damroimages/phone.svg\" alt=\"Phone\"\u003e Customer care number : \u003c/label\u003e\u003ca href=\"tel:+1800 425 1122\"\u003e1800 425 1122\u003c/a\u003e\u003c/div\u003e\u003cdiv class=\"footer_content_link\"\u003e\u003clabel\u003e\u003cimg src=\"https://damroimages.blob.core.windows.net/damroimages/phone.svg\" alt=\"Phone\"\u003e Alternate number : \u003c/label\u003e\u003ca href=\"tel:+918867764895\"\u003e+918867764895\u003c/a\u003e\u003c/div\u003e","content2":"\u003cdiv class=\"mb-0 footer_content_link\"\u003e\u003clabel\u003e\u003cimg src=\"https://damroimages.blob.core.windows.net/damroimages/email.svg\" alt=\"Email\"\u003eSales : \u003c/label\u003e\u003ca href=\"mailto:salessupport@damroindia.com\"\u003esalessupport@damroindia.com\u003c/a\u003e\u003c/div\u003e\n","content3":"\u003cdiv class=\"mb-0 footer_content_link\"\u003e\u003clabel\u003e\u003cimg src=\"https://damroimages.blob.core.windows.net/damroimages/email.svg\" alt=\"Email\"\u003eService : \u003c/label\u003e\u003ca href=\"mailto:service@damroindia.com\"\u003eservice@damroindia.com\u003c/a\u003e\u003c/div\u003e\n"},"weAcceptBlock":{"_id":"60acb31921ddbe134818e575","blockId":"5","title":"We Accept","content":"\u003ch5 class=\"footer_payment_heading\"\u003eWe Accept\u003c/h5\u003e\n\u003cul\n  class=\"d-flex align-items-center justify-content-start flex-wrap footer_payment_list\"\n\u003e\n  \u003cli class=\"footer_payment_list_item\"\u003e\n    \u003cbutton class=\"footer_payment_list_item_btn\"\u003e\n      \u003cimg\n        src=\"https://damroimages.blob.core.windows.net/damroimages/visa.svg\"\n        alt=\"payment_image\"\n      /\u003e\n    \u003c/button\u003e\n  \u003c/li\u003e\n  \u003cli class=\"footer_payment_list_item\"\u003e\n    \u003cbutton class=\"footer_payment_list_item_btn\"\u003e\n      \u003cimg\n        src=\"https://damroimages.blob.core.windows.net/damroimages/rupay.svg\"\n        alt=\"payment_image\"\n      /\u003e\n    \u003c/button\u003e\n  \u003c/li\u003e\n  \u003cli class=\"footer_payment_list_item\"\u003e\n    \u003cbutton class=\"footer_payment_list_item_btn\"\u003e\n 